{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "User UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "full_name": { "type": "string", "description": "User full name" },
        "avatar_url": { "type": "string", "description": "Profile picture URL" },
        "t_points": { "type": "number", "description": "Trust points" },
        "tier": { "type": "string", "enum": ["BRONZE", "SILVER", "GOLD"], "description": "User tier" },
        "is_verified": { "type": "boolean", "description": "KYC status" },
        "created_at": { "type": "string", "format": "date-time", "description": "Account creation date" }
      },
      "required": ["id", "email", "full_name", "t_points", "tier", "is_verified", "created_at"]
    },
    "Item": {
      "title": "Item",
      "description": "Rental item listing",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Item ID" },
        "owner_id": { "type": "string", "description": "Owner UID" },
        "title": { "type": "string", "description": "Item title" },
        "description": { "type": "string", "description": "Item description" },
        "category": { "type": "string", "description": "Item category" },
        "price_per_day": { "type": "number", "description": "Price per day" },
        "currency": { "type": "string", "enum": ["USD", "KHR"], "description": "Currency" },
        "image_url": { "type": "string", "description": "Item image URL" },
        "latitude": { "type": "number", "description": "Latitude" },
        "longitude": { "type": "number", "description": "Longitude" },
        "availability_status": { "type": "string", "enum": ["AVAILABLE", "RENTED", "MAINTENANCE"], "description": "Availability status" },
        "quantity": { "type": "number", "description": "Total quantity" },
        "rating_avg": { "type": "number", "description": "Average rating" }
      },
      "required": ["id", "owner_id", "title", "category", "price_per_day", "currency", "image_url", "latitude", "longitude", "availability_status", "quantity", "rating_avg"]
    },
    "Booking": {
      "title": "Booking",
      "description": "Rental booking record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Booking ID" },
        "renter_id": { "type": "string", "description": "Renter UID" },
        "item_id": { "type": "string", "description": "Item ID" },
        "item_title": { "type": "string", "description": "Item title" },
        "start_date": { "type": "string", "format": "date-time", "description": "Start date" },
        "end_date": { "type": "string", "format": "date-time", "description": "End date" },
        "total_price": { "type": "number", "description": "Total price" },
        "status": { "type": "string", "description": "Booking status" },
        "created_at": { "type": "string", "format": "date-time", "description": "Booking creation date" }
      },
      "required": ["id", "renter_id", "item_id", "item_title", "start_date", "end_date", "total_price", "status", "created_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "Profile",
      "description": "User profiles"
    },
    "/items/{itemId}": {
      "schema": "Item",
      "description": "Rental items"
    },
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Rental bookings"
    }
  }
}
